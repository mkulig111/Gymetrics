// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExerciseType {
  WEIGHT_REPS
  BODYWEIGHT_REPS
  TIME
}

enum SetType {
  WORK
  WARMUP
  DROP
  FAILURE
}

model Exercise {
  id        String       @id @default(cuid())
  name      String
  type      ExerciseType @default(WEIGHT_REPS)
  isCustom  Boolean      @default(false)
  createdAt DateTime     @default(now())

  routineExercises RoutineExercise[]
  workoutExercises WorkoutExercise[]
  bodyParts        ExerciseBodyPart[]
}

model BodyPart {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  exercises ExerciseBodyPart[]
}

model ExerciseBodyPart {
  id         String   @id @default(cuid())
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  bodyPartId String
  bodyPart   BodyPart @relation(fields: [bodyPartId], references: [id], onDelete: Cascade)
  percentage Float    @default(100)

  @@unique([exerciseId, bodyPartId])
}

model Routine {
  id        String   @id @default(cuid())
  name      String
  notes     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exercises RoutineExercise[]
  sessions  WorkoutSession[]
}

model RoutineExercise {
  id         String   @id @default(cuid())
  routineId  String
  routine    Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  order      Int
  notes      String?

  sets RoutineSet[]
}

model RoutineSet {
  id                String          @id @default(cuid())
  routineExerciseId String
  routineExercise   RoutineExercise @relation(fields: [routineExerciseId], references: [id], onDelete: Cascade)
  setIndex          Int
  targetReps        Int?
  targetWeightKg     Float?
  targetSeconds      Int?
}

model WorkoutSession {
  id          String    @id @default(cuid())
  routineId   String?
  routine     Routine?  @relation(fields: [routineId], references: [id])
  routineName String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  notes       String?

  exercises WorkoutExercise[]
}

model WorkoutExercise {
  id         String         @id @default(cuid())
  sessionId  String
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])
  order      Int

  sets WorkoutSet[]
}

model WorkoutSet {
  id                String          @id @default(cuid())
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  setIndex          Int
  type              SetType         @default(WORK)
  weightKg          Float?
  reps              Int?
  seconds           Int?
  completed         Boolean         @default(false)
  isPr              Boolean         @default(false)
}

model BodyweightEntry {
  id       String   @id @default(cuid())
  date     DateTime @default(now())
  weightKg Float
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  imageData String
}

model GripStrengthEntry {
  id   String   @id @default(cuid())
  date DateTime @default(now())
  kg   Float
}

model HrvEntry {
  id     String   @id @default(cuid())
  date   DateTime @default(now())
  rmssd  Float
}

model WellnessEntry {
  id    String   @id @default(cuid())
  date  DateTime @default(now())
  score Float
}
