# Prisma uses this connection string for PostgreSQL.
# Local dev: point at a Postgres instance you control (e.g. `docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16`).
# Railway: this is auto-injected when you attach a PostgreSQL plugin to the service — no need to set it manually.

DATABASE_URL="postgresql://user:password@localhost:5432/gymetrics"
